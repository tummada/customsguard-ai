{
  "name": "cgai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e:api": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:ext": "npx playwright test",
    "test:e2e:ext:manual": "npx playwright test --reporter=html",
    "test:e2e": "npm run test:e2e:api && npm run test:e2e:ext",
    "test:e2e:prod": "E2E_BASE_URL=https://api.vollos.ai vitest run --config vitest.e2e.config.ts e2e/api.e2e.test.ts"
  },
  "dependencies": {
    "big.js": "^6.2.2",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "i18next": "^25.8.14",
    "lucide-react": "^0.577.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.5.4"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.30",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/big.js": "^6.2.2",
    "@types/chrome": "^0.1.40",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
