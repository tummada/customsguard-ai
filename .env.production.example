# ==============================================================================
# VOLLOS Production Config — vollos.ai
# คัดลอกไฟล์นี้ไป VPS แล้วแก้ค่าจริง
# ==============================================================================
APP_NAME=VOLLOS
APP_ENV=production
APP_BASE_URL=https://api.vollos.ai
FRONTEND_URL=https://vollos.ai

# --- Database ---
DB_HOST=postgres
DB_USER=vollos_prod
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DB_NAME=vollos_db
DB_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# --- JWT (ต้องเปลี่ยน! ใช้: openssl rand -base64 48) ---
JWT_SECRET=CHANGE_ME_USE_openssl_rand_base64_48
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://vollos.ai,chrome-extension://

# --- S3 / MinIO ---
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_BUCKET_NAME=vollos-prod
S3_REGION=auto
S3_ENDPOINT=http://minio:9000

# --- Admin API (ต้องเปลี่ยน!) ---
ADMIN_SECRET=CHANGE_ME_USE_openssl_rand_base64_32

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# --- Gemini AI ---
GEMINI_API_KEY=CHANGE_ME_YOUR_REAL_KEY

# --- Email (optional for pilot) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@vollos.ai
SMTP_PASSWORD=CHANGE_ME

# --- Stripe (optional for pilot) ---
STRIPE_API_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# --- MinIO ---
MINIO_ROOT_USER=vollos_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# --- n8n Workflow (ต้องเปลี่ยน!) ---
N8N_ENCRYPTION_KEY=CHANGE_ME_N8N_ENCRYPTION_KEY
N8N_USER_MANAGEMENT_JWT_SECRET=CHANGE_ME_N8N_JWT
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD

# --- Domain (for SSL) ---
DOMAIN=vollos.ai
EMAIL=admin@vollos.ai
