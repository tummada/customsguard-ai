# ==============================================================================
# AI-SaaS World-Class: Infrastructure Config
# ==============================================================================
APP_NAME=AI-SaaS-World-Class
APP_ENV=production
APP_BASE_URL=https://api.your-ai-saas.com
FRONTEND_URL=https://your-ai-saas.com

# --- Database (PostgreSQL 16) ---
DB_HOST=postgres
DB_USER=saas_admin
DB_PASSWORD=YOUR_COMPLEX_PASSWORD_HERE
DB_NAME=ai_saas_db
DB_PORT=5432

# --- Cache & Broker (Redis 7) ---
REDIS_HOST=redis
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD
REDIS_PORT=6379

# ==============================================================================
# Backend Core (Spring Boot 3.5)
# ==============================================================================

# --- Security & Identity ---
JWT_SECRET=YOUR_SUPER_LONG_BASE64_SECRET
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000 
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# --- CORS Settings ---
# ป้องกันการยิง API จากโดเมนอื่นที่ไม่ได้รับอนุญาต
CORS_ALLOWED_ORIGINS=https://your-ai-saas.com,https://api.your-ai-saas.com

# --- Stripe Monetization ---
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CURRENCY=usd

# --- Object Storage (S3 / Cloudflare R2) ---
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=ai-saas-assets
S3_REGION=auto
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- Email Service (SMTP) ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=noreply@your-ai-saas.com

# --- Admin API (ต้องเปลี่ยน!) ---
ADMIN_SECRET=YOUR_ADMIN_SECRET_HERE

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ==============================================================================
# AI Workflow (n8n & AI Engine)
# ==============================================================================
N8N_ENCRYPTION_KEY=your_n8n_encryption_key
N8N_USER_MANAGEMENT_JWT_SECRET=your_n8n_jwt_secret
N8N_PATH=/n8n/
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD

AI_ENGINE_API_URL=https://your-gpu-worker-api.com
AI_ENGINE_API_KEY=your_api_key

# --- Gemini Embedding API (for CustomsGuard semantic search) ---
GEMINI_API_KEY=your_gemini_api_key_here